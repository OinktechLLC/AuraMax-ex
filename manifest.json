{
  "manifest_version": 3,
  "name": "OneMAX",
  "version": "1.0.0",
  "description": "Экономия трафика и приватность: сжатие, блокировка ads/trackers, VPN/Proxy",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "OneMAX"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "proxy",
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "webRequest",
    "webRequestBlocking",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules/rules.json"
      }
    ]
  }
}
